{
  "version": 2,
  "builds": [
    { "src": "index.html",      "use": "@vercel/static" },
    { "src": "admin.html",      "use": "@vercel/static" },
    { "src": "disc.html",       "use": "@vercel/static" },
    { "src": "nr1.html",        "use": "@vercel/static" },
    { "src": "nr1-admin.html",  "use": "@vercel/static" },
    { "src": "public/**",       "use": "@vercel/static" },
    { "src": "api/index.js",    "use": "@vercel/node" },
    { "src": "api/nr1.js",      "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/img/(.*)",            "dest": "/public/img/$1", "headers": { "Cache-Control": "public, max-age=31536000, immutable" } },

    { "src": "/api/nr1/(.*)",        "dest": "/api/nr1.js" },
    { "src": "/admin/nr1/(.*)",      "dest": "/api/nr1.js" },
    { "src": "/admin/nr1",           "dest": "/nr1-admin.html" },
    { "src": "/nr1-admin",           "dest": "/nr1-admin.html" },

    { "src": "/nr1/(.*)",            "dest": "/nr1.html" },
    { "src": "/nr1",                 "dest": "/nr1.html" },

    { "src": "/q/([A-Za-z0-9-]+)",   "dest": "/nr1.html?q=$1" },
    { "src": "/r/(RU[A-Za-z0-9-]+)", "dest": "/nr1.html?r=$1" },

    { "src": "/f/(.*)",              "dest": "/disc.html" },
    { "src": "/r/(.*)",              "dest": "/disc.html" },
    { "src": "/disc",                "dest": "/disc.html" },

    { "src": "/api/(.*)",            "dest": "/api/index.js" },
    { "src": "/admin/(.+)",          "dest": "/api/index.js" },
    { "src": "/admin",               "dest": "/admin.html" },

    { "src": "/(.*)",                "dest": "/index.html" }
  ],
  "env": {
    "BASE_URL": "https://www.perfilis.com"
  }
}
